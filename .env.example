# Supabase
SUPABASE_URL=
SUPABASE_KEY=
# Settings → API keys → Secret keys (sb_secret_...) — utilisée par /api/print/[slug]
SUPABASE_SECRET_KEY=

# Mistral (platform.mistral.ai → API Keys)
NUXT_MISTRAL_API_KEY=

# Secret HMAC pour les tokens de la page /print (openssl rand -hex 32)
NUXT_PRINT_TOKEN_SECRET=

# Tests E2E (optionnel) — compte dédié créé automatiquement via SUPABASE_SECRET_KEY,
# email/password par défaut codés dans e2e/global.setup.ts si absents
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
